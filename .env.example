# ==========================================
# DAIA - Environment Configuration Template
# ==========================================

# 1. Banco de Dados (MySQL)
MYSQL_ROOT_PASSWORD=root_password_segura
MYSQL_DATABASE=daia_db
MYSQL_USER=daia_user
MYSQL_PASSWORD=daia_password
MYSQL_HOST=db
MYSQL_PORT=3306

# 2. Backend (FastAPI)
# Usado para gerar e validar tokens JWT
SECRET_KEY=sua_chave_secreta_super_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 3. Inteligência Artificial (APIs)
# Preencha a chave da plataforma que for utilizar
OPENAI_API_KEY=sk-sua-chave-openai-aqui
# GEMINI_API_KEY=sua-chave-gemini-aqui

# 4. Frontend (React / Vite)
# Endereço base da API para chamadas do frontend
VITE_API_BASE_URL=http://localhost:8000
